# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/quickserve?schema=public"

# NextAuth / Auth.js
AUTH_SECRET="change-me-in-production"
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# WATI (WhatsApp Business API)
WATI_API_ENDPOINT="https://live-server-XXXX.wati.io"
WATI_ACCESS_TOKEN=""
WATI_CHANNEL_NUMBER=""
WATI_BROADCAST_NAME="quickserve"
# Secret partagé pour vérifier l'origine des webhooks (header x-wati-webhook-secret ou Bearer)
WATI_WEBHOOK_SECRET=""

# Google Sheets (sync menu + écriture Commandes/Reservations)
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
# Clé privée PEM ; conserver les \n échappés sur une seule ligne
GOOGLE_PRIVATE_KEY=""
DEMO_SPREADSHEET_ID=""
# Laisser vide en local : le seed utilise un placeholder. Renseigner l'ID du Sheet avant sync Sheets.

# Dashboard API (resync menu, update statut commande)
DASHBOARD_API_SECRET=""

# Cron quotidien (TRIAL expiré → SUSPENDED). Sur Vercel : même valeur, header Bearer auto.
CRON_SECRET=""

# Templates WATI staff (hors session 24h)
WATI_STAFF_ORDER_TEMPLATE="staff_new_order"
WATI_STAFF_RESERVATION_TEMPLATE="staff_new_reservation"
WATI_SESSION_EXPIRED_TEMPLATE="session_reopen"
WATI_WEBHOOK_RATE_LIMIT="120"

# Seed démo (optionnel — valeurs par défaut dans prisma/seed.ts)
DEMO_OWNER_EMAIL="owner@chez-douala.test"
DEMO_OWNER_PASSWORD="changeme123"
DEMO_ADMIN_EMAIL="admin@quickserve.test"
DEMO_ADMIN_PASSWORD="admin123456"
